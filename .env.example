# Токен бота из @BotFather
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Логика импульса ---
# Порог первого сигнала, % (старт от 30, как договорились)
IMPULSE_START_THRESHOLD=30.0

# Шаг повторных сигналов после первого, % (30 -> 40 -> 50 ...)
IMPULSE_STEP=10.0

# Скользящее окно расчёта импульса, минут (1440 = 24ч — движение учитывается
# в любой момент за последние сутки, без сброса счётчика)
WINDOW_MINUTES=1440

# --- Фильтр рынка ---
# Минимальный дневной объём в USDT — отсекает только полностью мёртвые пары
MIN_DAILY_VOLUME_USDT=1500000

# Как часто пересобирать список торгуемых пар и перезапускать WS-подписки (секунды)
# 86400 = 24ч — раз в сутки пробивает объёмы заново на обеих биржах
SYMBOLS_REFRESH_SEC=86400

# --- Ежедневный отчёт топ-10 ---
# Час отправки отчёта по UTC (17 = 20:00 Киев/Москва, UTC+3)
DAILY_REPORT_HOUR_UTC=17
DAILY_REPORT_MINUTE_UTC=0

# Сколько пар показывать в топе роста и топе падения
DAILY_REPORT_TOP_N=10

# --- Прочее ---
DB_PATH=bot_state.db
